<!-- 3D Animated Gallery Section -->
<!-- 3D Animated Gallery Section -->
<section class="gallery-section" id="gallery-section">
  <!-- 3D Canvas Background -->
  <canvas id="galleryCanvas" class="gallery-canvas"></canvas>
  
  <!-- Animated Grid Pattern -->
  <div class="grid-pattern">
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
  </div>
  
  <!-- Floating Light Orbs -->
  <div class="light-orbs" id="lightOrbs">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="orb orb-4"></div>
    <div class="orb orb-5"></div>
  </div>
  
  <!-- Section Header -->
  <div class="gallery-header">
    <div class="header-badge">
      <i class="fas fa-camera-retro"></i>
      <span>Our Moments</span>
    </div>
    <h2 class="gallery-title">
      <span class="title-line">Visual</span>
      <span class="title-highlight">Gallery</span>
      <span class="title-line">Experience</span>
    </h2>
    <p class="gallery-description">
      Explore the ambiance, cuisine, and unforgettable moments at VIVIDO
    </p>
  </div>
  
  <!-- Gallery Filter -->
  <div class="gallery-filter">
    <% galleryFilters.forEach((filter) => { %>
      <button class="filter-btn <%= filter.id === 'all' ? 'active' : '' %>" data-filter="<%= filter.id %>">
        <i class="fas <%= filter.icon %>"></i> <%= filter.label %>
      </button>
    <% }) %>
  </div>
  
  <!-- 3D Gallery Grid -->
  <div class="gallery-grid" id="galleryGrid">
    <% galleryItems.forEach((item, index) => { %>
      <article class="gallery-item visible" data-category="<%= item.category %>" data-index="<%= index %>" data-title="<%= item.title %>" data-desc="<%= item.description %>" data-icon="<%= item.icon %>" data-gradient="<%= item.gradient %>">
        <div class="gallery-card-3d">
          <div class="card-inner">
            <div class="card-front">
              <div class="image-wrapper">
                <div class="image-placeholder <%= item.imageClass %>">
                  <i class="fas <%= item.icon %>"></i>
                  <div class="image-overlay"></div>
                </div>
                <% if (item.badge) { %>
                  <div class="card-badge <%= item.badge.type %>">
                    <i class="fas <%= item.badge.icon %>"></i> <%= item.badge.label %>
                  </div>
                <% } %>
              </div>
              <div class="card-info">
                <h4><%= item.title %></h4>
                <p><%= item.subtitle %></p>
              </div>
            </div>
            <div class="card-back">
              <div class="back-content">
                <i class="fas <%= item.icon %> back-icon"></i>
                <h4><%= item.backTitle %></h4>
                <p><%= item.description %></p>
                <div class="back-stats">
                  <span><i class="fas fa-heart"></i> <%= item.likes %></span>
                  <span><i class="fas fa-eye"></i> <%= item.views %></span>
                </div>
                <button class="view-more-btn" type="button">
                  <i class="fas fa-expand"></i> View Full
                </button>
              </div>
            </div>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
  
  <!-- Load More Button -->
  <div class="gallery-cta">
    <button class="load-more-btn">
      <span>Load More Photos</span>
      <i class="fas fa-images"></i>
      <span class="btn-shine"></span>
    </button>
  </div>
  
  <!-- Lightbox Modal - Fixed to not hide entire page -->
  <div class="lightbox-modal" id="lightboxModal" style="display: none;">
    <div class="lightbox-overlay"></div>
    <div class="lightbox-content">
      <button class="lightbox-close" id="lightboxClose">
        <i class="fas fa-times"></i>
      </button>
      <button class="lightbox-nav prev" id="lightboxPrev">
        <i class="fas fa-chevron-left"></i>
      </button>
      <div class="lightbox-image-container">
        <div class="lightbox-image" id="lightboxImage">
          <i class="fas fa-image"></i>
        </div>
        <div class="lightbox-info">
          <h3 id="lightboxTitle">Image Title</h3>
          <p id="lightboxDesc">Image Description</p>
          <div class="lightbox-actions">
            <button id="lightboxLike"><i class="fas fa-heart"></i> Like</button>
            <button id="lightboxShare"><i class="fas fa-share"></i> Share</button>
            <button id="lightboxDownload"><i class="fas fa-download"></i> Download</button>
          </div>
        </div>
      </div>
      <button class="lightbox-nav next" id="lightboxNext">
        <i class="fas fa-chevron-right"></i>
      </button>
    </div>
  </div>
</section>

<!-- 3D Animated Contact Section -->
<section class="contact-section" id="contact-section">
  <!-- 3D Canvas Background -->
  <canvas id="contactCanvas" class="contact-canvas"></canvas>
  
  <!-- Animated Wave Background -->
  <div class="contact-waves">
    <div class="wave wave-1"></div>
    <div class="wave wave-2"></div>
    <div class="wave wave-3"></div>
  </div>
  
  <!-- Floating Glow Orbs -->
  <div class="glow-orbs">
    <div class="glow-orb orb-a"></div>
    <div class="glow-orb orb-b"></div>
    <div class="glow-orb orb-c"></div>
    <div class="glow-orb orb-d"></div>
  </div>
  
  <!-- Section Header -->
  <div class="contact-header">
    <div class="header-badge">
      <i class="fas fa-envelope-open-text"></i>
      <span>Get In Touch</span>
    </div>
    <h2 class="contact-title">
      <span class="title-line">Contact</span>
      <span class="title-highlight">With Us</span>
    </h2>
    <p class="contact-description">
      We'd love to hear from you. Reach out for reservations, inquiries, or special requests.
    </p>
  </div>
  
  <!-- Contact Content -->
  <div class="contact-content">
    <!-- Left Side - Contact Info Cards -->
    <div class="contact-info-side">
      <!-- Info Card 1 - Address -->
      <div class="info-card-3d" data-delay="0">
        <div class="info-card-inner">
          <div class="info-icon-wrapper">
            <div class="info-icon-ring"></div>
            <i class="fas fa-map-marker-alt info-icon"></i>
          </div>
          <div class="info-content">
            <h4>Our Location</h4>
            <p>123 Gourmet Street</p>
            <p>Little Italy, NY 10013</p>
            <a href="#" class="info-link">
              <i class="fas fa-directions"></i> Get Directions
            </a>
          </div>
        </div>
      </div>
      
      <!-- Info Card 2 - Phone -->
      <div class="info-card-3d" data-delay="0.2">
        <div class="info-card-inner">
          <div class="info-icon-wrapper">
            <div class="info-icon-ring"></div>
            <i class="fas fa-phone-alt info-icon"></i>
          </div>
          <div class="info-content">
            <h4>Call Us</h4>
            <p>+1 (555) 123-4567</p>
            <p>+1 (555) 987-6543</p>
            <a href="tel:+15551234567" class="info-link">
              <i class="fas fa-phone"></i> Call Now
            </a>
          </div>
        </div>
      </div>
      
      <!-- Info Card 3 - Email -->
      <div class="info-card-3d" data-delay="0.4">
        <div class="info-card-inner">
          <div class="info-icon-wrapper">
            <div class="info-icon-ring"></div>
            <i class="fas fa-envelope info-icon"></i>
          </div>
          <div class="info-content">
            <h4>Email Us</h4>
            <p>info@vivido.com</p>
            <p>reservations@vivido.com</p>
            <a href="mailto:info@vivido.com" class="info-link">
              <i class="fas fa-paper-plane"></i> Send Email
            </a>
          </div>
        </div>
      </div>
      
      <!-- Info Card 4 - Hours -->
      <div class="info-card-3d" data-delay="0.6">
        <div class="info-card-inner">
          <div class="info-icon-wrapper">
            <div class="info-icon-ring"></div>
            <i class="far fa-clock info-icon"></i>
          </div>
          <div class="info-content">
            <h4>Opening Hours</h4>
            <p><span>Mon - Thu:</span> 11AM - 10PM</p>
            <p><span>Fri - Sun:</span> 11AM - 11PM</p>
            <div class="open-badge">
              <i class="fas fa-circle"></i> Open Now
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Right Side - 3D Contact Form -->
    <div class="contact-form-side">
      <div class="form-container-3d">
        <div class="form-glow-border"></div>
        
        <div class="form-header">
          <i class="fas fa-pen-fancy"></i>
          <h3>Send Us a Message</h3>
        </div>
        
        <form class="contact-form" id="contactForm" action="/api/contact" method="POST">
          <div class="input-group-3d">
            <div class="input-wrapper">
              <i class="fas fa-user input-icon"></i>
              <input type="text" id="name" name="name" required placeholder="Your Name">
              <label for="name">Full Name</label>
              <span class="input-border"></span>
            </div>
          </div>
          
          <div class="input-group-3d">
            <div class="input-wrapper">
              <i class="fas fa-envelope input-icon"></i>
              <input type="email" id="email" name="email" required placeholder="Your Email">
              <label for="email">Email Address</label>
              <span class="input-border"></span>
            </div>
          </div>
          
          <div class="input-group-3d">
            <div class="input-wrapper">
              <i class="fas fa-phone input-icon"></i>
              <input type="tel" id="phone" name="phone" placeholder="Your Phone">
              <!-- <label for="phone">Phone Number</label> -->
              <span class="input-border"></span>
            </div>
          </div>
          
          <div class="input-group-3d">
            <div class="input-wrapper">
              <i class="fas fa-tag input-icon"></i>
              <select id="subject" name="subject">
                <option value="" disabled selected>Select Subject</option>
                <option value="reservation">Table Reservation</option>
                <option value="event">Private Event</option>
                <option value="catering">Catering Service</option>
                <option value="feedback">Feedback</option>
                <option value="other">Other Inquiry</option>
              </select>
              <label for="subject">Subject</label>
              <span class="input-border"></span>
            </div>
          </div>
          
          <div class="input-group-3d">
            <div class="input-wrapper textarea-wrapper">
              <i class="fas fa-comment-dots input-icon"></i>
              <textarea id="message" name="message" rows="4" required placeholder="Your Message"></textarea>
              <label for="message">Message</label>
              <span class="input-border"></span>
            </div>
          </div>
          
          <button type="submit" class="submit-btn-3d">
            <span class="btn-text">Send Message</span>
            <i class="fas fa-paper-plane"></i>
            <span class="btn-ripple"></span>
          </button>
        </form>
        
        <!-- Success Message (Hidden by default) -->
        <div class="success-message" id="successMessage">
          <div class="success-icon">
            <i class="fas fa-check-circle"></i>
          </div>
          <h3>Message Sent Successfully!</h3>
          <p>We'll get back to you within 24 hours.</p>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Social Media Links -->
  <div class="social-links-3d">
    <a href="#" class="social-btn" data-platform="facebook">
      <i class="fab fa-facebook-f"></i>
      <span class="social-tooltip">Facebook</span>
    </a>
    <a href="#" class="social-btn" data-platform="instagram">
      <i class="fab fa-instagram"></i>
      <span class="social-tooltip">Instagram</span>
    </a>
    <a href="#" class="social-btn" data-platform="twitter">
      <i class="fab fa-twitter"></i>
      <span class="social-tooltip">Twitter</span>
    </a>
    <a href="#" class="social-btn" data-platform="tripadvisor">
      <i class="fab fa-tripadvisor"></i>
      <span class="social-tooltip">TripAdvisor</span>
    </a>
    <a href="#" class="social-btn" data-platform="youtube">
      <i class="fab fa-youtube"></i>
      <span class="social-tooltip">YouTube</span>
    </a>
  </div>
  
  <!-- Map Placeholder -->
  <div class="map-container-3d">
    <div class="map-placeholder">
      <i class="fas fa-map-marked-alt map-icon"></i>
      <div class="map-pulse"></div>
      <span>Find Us on Map</span>
    </div>
  </div>
  
  <!-- Floating Decorative Icons -->
  <div class="floating-contact-icons">
    <i class="fas fa-utensils fci-1"></i>
    <i class="fas fa-wine-glass-alt fci-2"></i>
    <i class="fas fa-pizza-slice fci-3"></i>
    <i class="fas fa-coffee fci-4"></i>
    <i class="fas fa-ice-cream fci-5"></i>
  </div>
</section>
  </main>


  <div class="reservation-modal" id="reservationModal" aria-hidden="true">
    <div class="reservation-overlay" data-close-reservation></div>
    <form class="reservation-panel" id="reservationForm" action="/api/reservations" method="POST">
      <button class="reservation-close" type="button" data-close-reservation aria-label="Close reservation form">
        <i class="fas fa-times"></i>
      </button>
      <div class="form-header">
        <i class="fas fa-chair"></i>
        <h3>Book a Table</h3>
      </div>
      <div class="reservation-grid">
        <input type="text" name="name" placeholder="Full name" required>
        <input type="email" name="email" placeholder="Email address" required>
        <input type="tel" name="phone" placeholder="Phone number">
        <input type="date" name="date" required>
        <input type="time" name="time" required>
        <input type="number" name="guests" min="1" max="20" placeholder="Guests" required>
      </div>
      <textarea name="notes" rows="3" placeholder="Special requests"></textarea>
      <button type="submit" class="submit-btn-3d">
        <span class="btn-text">Confirm Request</span>
        <i class="fas fa-paper-plane"></i>
      </button>
      <p class="reservation-status" id="reservationStatus"></p>
    </form>
  </div>

  <script>window.galleryData = <%- JSON.stringify(galleryItems) %>;</script>
  <script src="/js/script.js"></script>
