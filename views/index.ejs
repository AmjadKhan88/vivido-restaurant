<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= title %></title>
  <!-- Font Awesome 6 for crisp icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <!-- Three.js Library -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <!-- GSAP + ScrollTrigger -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</head>
<body>
  <!-- Sticky 3D Animated Navbar - Always at top -->
  <header class="navbar-header">
    <nav class="navbar-3d" id="navbar">
      <!-- Logo -->
      <div class="logo-area">
        <i class="fas fa-utensils logo-icon"></i>
        <span class="logo-text">VIVIDO</span>
        <i class="fas fa-star logo-star"></i>
      </div>

      <!-- Navigation Links - Desktop -->
      <ul class="nav-links" id="navLinks">
        <li class="nav-item active">
          <a href="#home" class="nav-link"><i class="fas fa-home"></i> Home</a>
        </li>
        <li class="nav-item">
          <a href="#menu-section" class="nav-link"><i class="fas fa-book-open"></i> Menu</a>
        </li>
        <li class="nav-item">
          <a href="#bar-section" class="nav-link"><i class="fas fa-wine-glass-alt"></i> Bar</a>
        </li>
        <li class="nav-item">
          <a href="#events-section" class="nav-link"><i class="fas fa-calendar-alt"></i> Events</a>
        </li>
        <li class="nav-item">
          <a href="#gallery-section" class="nav-link"><i class="fas fa-camera-retro"></i> Gallery</a>
        </li>
        <li class="nav-item">
          <a href="#contact-section" class="nav-link"><i class="fas fa-envelope"></i> Contact</a>
        </li>
      </ul>

      <!-- Reservation CTA -->
      <div class="reserve-btn-3d">
        <button class="btn-reserve" id="reserveButton">
          <i class="fas fa-calendar-check"></i>
          <span>Reserve</span>
        </button>
      </div>

      <!-- Mobile menu toggle - positioned at the end for mobile -->
      <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>

      <!-- floating decorative element -->
      <div class="food-float">
        <i class="fas fa-pizza-slice"></i>
      </div>
    </nav>
  </header>

  <!-- Main content area - ready for additional sections -->
  <main class="main-content">
    <!-- Hero Section -->
  <section class="hero-section" id="home">
    <!-- 3D Canvas Background -->
    <canvas id="heroCanvas" class="hero-canvas"></canvas>
    
    <!-- Floating Particles -->
    <div class="floating-particles" id="floatingParticles"></div>
    
    <!-- Animated Gradient Overlay -->
    <div class="gradient-overlay"></div>
    
    <!-- Main Content -->
    <div class="hero-content">
      <!-- Left Side - Text Content -->
      <div class="hero-text-content">
        <div class="hero-badge">
          <i class="fas fa-award badge-icon"></i>
          <span>Authentic Italian • Since 1998</span>
        </div>
        
        <h1 class="hero-title">
          <span class="title-line-1">Experience the</span>
          <span class="title-highlight">Fiza Palette</span>
          <span class="title-line-2">of Flavors</span>
        </h1>
        
        <p class="hero-description">
          Indulge in our signature wood-fired pizzas crafted with passion, 
          premium ingredients, and centuries-old traditions.
        </p>
        
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">50+</span>
            <span class="stat-label">Pizza Varieties</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">4.9</span>
            <span class="stat-label">Rating</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">25k+</span>
            <span class="stat-label">Happy Customers</span>
          </div>
        </div>
        
        <div class="hero-cta-group">
          <button class="cta-primary">
            <i class="fas fa-pizza-slice"></i>
            Explore Menu
          </button>
          <button class="cta-secondary">
            <i class="fas fa-play-circle"></i>
            Watch Video
          </button>
        </div>
      </div>
      
      <!-- Right Side - 3D Pizza Floating -->
      <div class="hero-visual">
        <div class="pizza-container" id="pizzaContainer">
          <!-- 3D pizza will be rendered here -->
        </div>
        <div class="floating-ingredients">
          <i class="fas fa-cheese ingredient cheese"></i>
          <i class="fas fa-pepper-hot ingredient pepper"></i>
          <i class="fas fa-leaf ingredient basil"></i>
          <i class="fas fa-tomato ingredient tomato"></i>
        </div>
      </div>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="scroll-indicator">
      <span>Scroll to explore</span>
      <i class="fas fa-chevron-down"></i>
      <i class="fas fa-chevron-down"></i>
    </div>
    
    <!-- Animated Food Elements -->
    <div class="food-elements">
      <i class="fas fa-pizza-slice element-1"></i>
      <i class="fas fa-wine-bottle element-2"></i>
      <i class="fas fa-utensils element-3"></i>
      <i class="fas fa-seedling element-4"></i>
    </div>
  </section>


    <!-- Sample sections to demonstrate scroll behavior -->
    <!-- Animated 3D Menu Section -->
<section class="menu-section" id="menu-section">
  <!-- Background Animation -->
  <div class="menu-bg-animation">
    <div class="bg-circle circle-1"></div>
    <div class="bg-circle circle-2"></div>
    <div class="bg-circle circle-3"></div>
  </div>
  
  <!-- Section Header -->
  <div class="menu-header">
    <span class="menu-subtitle">Our Signature</span>
    <h2 class="menu-title">
      <span class="title-icon"><i class="fas fa-utensils"></i></span>
      Fiza Palette Menu
    </h2>
    <p class="menu-description">
      Handcrafted with passion, baked to perfection in wood-fired ovens
    </p>
  </div>
  
  <!-- Category Filter -->
  <div class="menu-categories">
    <% categories.forEach((category) => { %>
      <button class="category-btn <%= category.id === 'all' ? 'active' : '' %>" data-category="<%= category.id %>">
        <i class="fas <%= category.icon %>"></i> <%= category.label %>
      </button>
    <% }) %>
  </div>
  
  <!-- 3D Menu Cards Container -->
  <div class="menu-grid" id="menuGrid">
    <% menuItems.forEach((item) => { %>
      <article class="menu-card" data-category="<%= item.category %>">
        <div class="card-3d-wrapper">
          <div class="card-front">
            <div class="card-image" style="background-image: linear-gradient(180deg, rgba(13,10,8,0.12), rgba(13,10,8,0.62)), url('<%= item.image %>');">
              <div class="food-3d-icon">
                <i class="fas <%= item.icon %>"></i>
              </div>
              <% if (item.badge) { %>
                <div class="card-badge <%= item.badge.type %>">
                  <i class="fas <%= item.badge.icon %>"></i> <%= item.badge.label %>
                </div>
              <% } %>
            </div>
            <div class="card-content">
              <h3 class="food-name"><%= item.name %></h3>
              <p class="food-description"><%= item.description %></p>
              <div class="card-footer">
                <span class="food-price">$<%= item.price.toFixed(2) %></span>
                <button class="add-to-cart" data-item-id="<%= item.id %>" type="button">
                  <i class="fas fa-plus"></i> Add
                </button>
              </div>
            </div>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
  
  <!-- View Full Menu Button -->
  <div class="menu-cta">
    <button class="view-full-menu">
      <span>View Full Menu</span>
      <i class="fas fa-arrow-right"></i>
    </button>
  </div>
</section>

<!-- 3D Animated Bar Section -->
<section class="bar-section" id="bar-section">
  <!-- 3D Canvas Background -->
  <canvas id="barCanvas" class="bar-canvas"></canvas>
  
  <!-- Floating Liquid Effect -->
  <div class="liquid-background">
    <div class="liquid-wave wave-1"></div>
    <div class="liquid-wave wave-2"></div>
    <div class="liquid-wave wave-3"></div>
  </div>
  
  <!-- Neon Particles -->
  <div class="neon-particles" id="neonParticles"></div>
  
  <!-- Section Content -->
  <div class="bar-content">
    <!-- Left Side - 3D Drink Showcase -->
    <div class="bar-visual">
      <div class="drink-3d-container" id="drinkContainer">
        <!-- 3D Drink will be rendered here -->
        <div class="drink-reflection"></div>
      </div>
      
      <!-- Floating Ingredients -->
      <div class="floating-items">
        <div class="float-item item-1">
          <i class="fas fa-lemon"></i>
        </div>
        <div class="float-item item-2">
          <i class="fas fa-candy-cane"></i>
        </div>
        <div class="float-item item-3">
          <i class="fas fa-mint"></i>
        </div>
        <div class="float-item item-4">
          <i class="fas fa-cherry"></i>
        </div>
        <div class="float-item item-5">
          <i class="fas fa-cocktail"></i>
        </div>
      </div>
    </div>
    
    <!-- Right Side - Menu & Info -->
    <div class="bar-info">
      <div class="bar-header">
        <div class="bar-badge neon-text">
          <i class="fas fa-glass-cheers"></i>
          <span>Premium Bar</span>
        </div>
        <h2 class="bar-title">
          <span class="title-neon">Signature</span>
          <span class="title-highlight">Cocktails</span>
        </h2>
        <p class="bar-subtitle">
          Expertly crafted drinks that elevate your dining experience
        </p>
      </div>
      
      <!-- Drink Categories -->
      <div class="drink-tabs">
        <button class="tab-btn active" data-tab="cocktails">
          <i class="fas fa-cocktail"></i> Cocktails
        </button>
        <button class="tab-btn" data-tab="mocktails">
          <i class="fas fa-glass-water"></i> Mocktails
        </button>
        <button class="tab-btn" data-tab="hot">
          <i class="fas fa-mug-hot"></i> Hot Drinks
        </button>
      </div>
      
      <!-- Drinks Menu Cards -->
      <div class="drinks-container" id="drinksContainer">
        <!-- Cocktails -->
        <div class="drink-card" data-category="cocktails">
          <div class="drink-visual">
            <div class="drink-icon">
              <i class="fas fa-martini-glass"></i>
            </div>
            <div class="drink-color color-1"></div>
          </div>
          <div class="drink-details">
            <div class="drink-header">
              <h3>Neon Martini</h3>
              <span class="drink-price">$14.99</span>
            </div>
            <p>Vodka, blue curaçao, fresh lime, glowing garnish</p>
            <div class="drink-meta">
              <span><i class="fas fa-star"></i> 4.9</span>
              <span><i class="fas fa-fire"></i> Signature</span>
            </div>
            <button class="order-btn">
              <i class="fas fa-plus"></i> Order Now
            </button>
          </div>
        </div>
        
        <div class="drink-card" data-category="cocktails">
          <div class="drink-visual">
            <div class="drink-icon">
              <i class="fas fa-whiskey-glass"></i>
            </div>
            <div class="drink-color color-2"></div>
          </div>
          <div class="drink-details">
            <div class="drink-header">
              <h3>Smoky Old Fashioned</h3>
              <span class="drink-price">$16.99</span>
            </div>
            <p>Bourbon, smoked wood, bitters, orange twist</p>
            <div class="drink-meta">
              <span><i class="fas fa-star"></i> 4.8</span>
              <span><i class="fas fa-crown"></i> Premium</span>
            </div>
            <button class="order-btn">
              <i class="fas fa-plus"></i> Order Now
            </button>
          </div>
        </div>
        
        <div class="drink-card" data-category="cocktails">
          <div class="drink-visual">
            <div class="drink-icon">
              <i class="fas fa-champagne-glasses"></i>
            </div>
            <div class="drink-color color-3"></div>
          </div>
          <div class="drink-details">
            <div class="drink-header">
              <h3>Fiza Spritz</h3>
              <span class="drink-price">$13.99</span>
            </div>
            <p>Aperol, prosecco, soda, blood orange, rosemary</p>
            <div class="drink-meta">
              <span><i class="fas fa-star"></i> 4.9</span>
              <span><i class="fas fa-fire"></i> Popular</span>
            </div>
            <button class="order-btn">
              <i class="fas fa-plus"></i> Order Now
            </button>
          </div>
        </div>
        
        <!-- Mocktails -->
        <div class="drink-card hidden" data-category="mocktails">
          <div class="drink-visual">
            <div class="drink-icon">
              <i class="fas fa-glass-water"></i>
            </div>
            <div class="drink-color color-4"></div>
          </div>
          <div class="drink-details">
            <div class="drink-header">
              <h3>Virgin Mojito</h3>
              <span class="drink-price">$9.99</span>
            </div>
            <p>Fresh mint, lime, soda, sugar cane, crushed ice</p>
            <div class="drink-meta">
              <span><i class="fas fa-star"></i> 4.7</span>
              <span><i class="fas fa-leaf"></i> Fresh</span>
            </div>
            <button class="order-btn">
              <i class="fas fa-plus"></i> Order Now
            </button>
          </div>
        </div>
        
        <div class="drink-card hidden" data-category="mocktails">
          <div class="drink-visual">
            <div class="drink-icon">
              <i class="fas fa-citrus-slice"></i>
            </div>
            <div class="drink-color color-5"></div>
          </div>
          <div class="drink-details">
            <div class="drink-header">
              <h3>Tropical Paradise</h3>
              <span class="drink-price">$11.99</span>
            </div>
            <p>Mango, passion fruit, coconut cream, pineapple</p>
            <div class="drink-meta">
              <span><i class="fas fa-star"></i> 4.8</span>
              <span><i class="fas fa-sun"></i> Tropical</span>
            </div>
            <button class="order-btn">
              <i class="fas fa-plus"></i> Order Now
            </button>
          </div>
        </div>
        
        <!-- Hot Drinks -->
        <div class="drink-card hidden" data-category="hot">
          <div class="drink-visual">
            <div class="drink-icon">
              <i class="fas fa-mug-hot"></i>
            </div>
            <div class="drink-color color-6"></div>
          </div>
          <div class="drink-details">
            <div class="drink-header">
              <h3>Italian Espresso</h3>
              <span class="drink-price">$5.99</span>
            </div>
            <p>Double shot, dark roast, crema perfecta</p>
            <div class="drink-meta">
              <span><i class="fas fa-star"></i> 4.9</span>
              <span><i class="fas fa-coffee"></i> Classic</span>
            </div>
            <button class="order-btn">
              <i class="fas fa-plus"></i> Order Now
            </button>
          </div>
        </div>
        
        <div class="drink-card hidden" data-category="hot">
          <div class="drink-visual">
            <div class="drink-icon">
              <i class="fas fa-mug-saucer"></i>
            </div>
            <div class="drink-color color-7"></div>
          </div>
          <div class="drink-details">
            <div class="drink-header">
              <h3>Hot Chocolate Luxe</h3>
              <span class="drink-price">$8.99</span>
            </div>
            <p>Belgian chocolate, whipped cream, marshmallows</p>
            <div class="drink-meta">
              <span><i class="fas fa-star"></i> 4.8</span>
              <span><i class="fas fa-heart"></i> Loved</span>
            </div>
            <button class="order-btn">
              <i class="fas fa-plus"></i> Order Now
            </button>
          </div>
        </div>
      </div>
      
      <!-- Happy Hour Banner -->
      <div class="happy-hour">
        <div class="happy-hour-content">
          <i class="fas fa-clock"></i>
          <div class="happy-text">
            <span class="happy-title">Happy Hour</span>
            <span class="happy-time">4PM - 7PM • 30% Off All Cocktails</span>
          </div>
        </div>
        <div class="countdown" id="countdown">
          <span>Ends in: <strong id="countdownTimer">02:45:30</strong></span>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Animated Bar Elements -->
  <div class="bar-elements">
    <div class="bar-stool stool-1"></div>
    <div class="bar-stool stool-2"></div>
    <div class="bar-counter"></div>
  </div>
</section>

<!-- 3D Animated Events Section -->
<section class="events-section" id="events-section">
  <!-- 3D Canvas Background -->
  <canvas id="eventsCanvas" class="events-canvas"></canvas>
  
  <!-- Animated Light Beams -->
  <div class="light-beams">
    <div class="beam beam-1"></div>
    <div class="beam beam-2"></div>
    <div class="beam beam-3"></div>
    <div class="beam beam-4"></div>
    <div class="beam beam-5"></div>
  </div>
  
  <!-- Floating Confetti Particles -->
  <div class="confetti-container" id="confettiContainer"></div>
  
  <!-- Section Header -->
  <div class="events-header">
    <div class="header-badge">
      <i class="fas fa-calendar-star"></i>
      <span>Don't Miss Out</span>
    </div>
    <h2 class="events-title">
      <span class="title-up">Upcoming</span>
      <span class="title-highlight">Events</span>
      <span class="title-sub">& Experiences</span>
    </h2>
    <p class="events-description">
      Join us for unforgettable culinary journeys and exclusive dining experiences
    </p>
  </div>
  
  <!-- Events Carousel Container -->
  <div class="events-carousel-container">
    <!-- Navigation Arrows -->
    <button class="carousel-arrow prev-arrow" id="prevEvent">
      <i class="fas fa-chevron-left"></i>
      <span class="arrow-glow"></span>
    </button>
    
    <!-- Events Cards Wrapper -->
    <div class="events-wrapper" id="eventsWrapper">
      <!-- Event Card 1 - Wine Tasting -->
      <div class="event-card active" data-event="1">
        <div class="event-3d-container">
          <div class="event-visual">
            <div class="event-icon-container">
              <i class="fas fa-wine-bottle event-icon"></i>
              <div class="event-orbit">
                <div class="orbit-particle"></div>
                <div class="orbit-particle"></div>
                <div class="orbit-particle"></div>
              </div>
            </div>
            <div class="event-date-badge">
              <span class="date-day">15</span>
              <span class="date-month">JUL</span>
            </div>
            <div class="event-time-badge">
              <i class="far fa-clock"></i> 7:00 PM
            </div>
          </div>
          
          <div class="event-content">
            <div class="event-category">
              <i class="fas fa-star"></i> Exclusive Tasting
            </div>
            <h3 class="event-name">Grand Wine Tasting Evening</h3>
            <p class="event-description">
              Explore a curated selection of premium beverages paired with artisanal cheeses and gourmet bites in an elegant setting.
            </p>
            
            <div class="event-features">
              <div class="feature">
                <i class="fas fa-glass-cheers"></i>
                <span>20+ Varieties</span>
              </div>
              <div class="feature">
                <i class="fas fa-cheese"></i>
                <span>Cheese Pairing</span>
              </div>
              <div class="feature">
                <i class="fas fa-user-tie"></i>
                <span>Expert Guide</span>
              </div>
            </div>
            
            <div class="event-footer">
              <div class="event-price">
                <span class="price-label">Per Person</span>
                <span class="price-value">$89</span>
              </div>
              <button class="book-event-btn">
                <span>Reserve Spot</span>
                <i class="fas fa-arrow-right"></i>
              </button>
            </div>
            
            <div class="event-spots">
              <i class="fas fa-users"></i>
              <span>Only <strong>12 spots</strong> remaining</span>
              <div class="spots-bar">
                <div class="spots-fill"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Event Card 2 - Live Music -->
      <div class="event-card" data-event="2">
        <div class="event-3d-container">
          <div class="event-visual">
            <div class="event-icon-container">
              <i class="fas fa-music event-icon"></i>
              <div class="event-orbit">
                <div class="orbit-particle"></div>
                <div class="orbit-particle"></div>
                <div class="orbit-particle"></div>
              </div>
            </div>
            <div class="event-date-badge">
              <span class="date-day">22</span>
              <span class="date-month">JUL</span>
            </div>
            <div class="event-time-badge">
              <i class="far fa-clock"></i> 8:00 PM
            </div>
          </div>
          
          <div class="event-content">
            <div class="event-category">
              <i class="fas fa-music"></i> Live Entertainment
            </div>
            <h3 class="event-name">Jazz Night Under Stars</h3>
            <p class="event-description">
              Experience soulful jazz performances while enjoying our special 5-course tasting menu with signature cocktails.
            </p>
            
            <div class="event-features">
              <div class="feature">
                <i class="fas fa-saxophone"></i>
                <span>Live Jazz Band</span>
              </div>
              <div class="feature">
                <i class="fas fa-utensils"></i>
                <span>5-Course Meal</span>
              </div>
              <div class="feature">
                <i class="fas fa-cocktail"></i>
                <span>Welcome Drink</span>
              </div>
            </div>
            
            <div class="event-footer">
              <div class="event-price">
                <span class="price-label">Per Person</span>
                <span class="price-value">$120</span>
              </div>
              <button class="book-event-btn">
                <span>Reserve Spot</span>
                <i class="fas fa-arrow-right"></i>
              </button>
            </div>
            
            <div class="event-spots">
              <i class="fas fa-users"></i>
              <span>Only <strong>8 spots</strong> remaining</span>
              <div class="spots-bar">
                <div class="spots-fill" style="width: 70%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Event Card 3 - Cooking Class -->
      <div class="event-card" data-event="3">
        <div class="event-3d-container">
          <div class="event-visual">
            <div class="event-icon-container">
              <i class="fas fa-fire-burner event-icon"></i>
              <div class="event-orbit">
                <div class="orbit-particle"></div>
                <div class="orbit-particle"></div>
                <div class="orbit-particle"></div>
              </div>
            </div>
            <div class="event-date-badge">
              <span class="date-day">29</span>
              <span class="date-month">JUL</span>
            </div>
            <div class="event-time-badge">
              <i class="far fa-clock"></i> 3:00 PM
            </div>
          </div>
          
          <div class="event-content">
            <div class="event-category">
